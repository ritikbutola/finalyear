.env.example file - Copy to .env and fill in your values

# ─── Node Signaling Server ────────────────────────────────────────────────────
PORT=3011
NODE_ENV=development
LOG_LEVEL=debug
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ─── RAG Backend (Python) ─────────────────────────────────────────────────────
# Get your GROQ API key from https://console.groq.com
GROQ_API_KEY=gsk_your_actual_key_here

# Embedding model (download happens on first use)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM Model to use (must be available in Groq)
LLM_MODEL=llama-3.1-8b-instant

# LLM parameters
LLM_TEMPERATURE=0.1
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K_FINAL=5

# CORS origins for RAG backend
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8000

# ─── React Frontend (Vite) ────────────────────────────────────────────────────
VITE_RAG_CHATBOT_URL=http://localhost:8000
VITE_SIGNALING_URL=http://localhost:3011
VITE_ENVIRONMENT=development
